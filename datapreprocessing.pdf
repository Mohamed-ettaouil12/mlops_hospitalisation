const {
  Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
  HeadingLevel, AlignmentType, BorderStyle, WidthType, ShadingType,
  LevelFormat, PageBreak, Header, Footer
} = require('docx');
const fs = require('fs');

// ── Helpers ──────────────────────────────────────────────────────────────────
const B = { style: BorderStyle.SINGLE, size: 1, color: "D1D5DB" };
const borders = { top: B, bottom: B, left: B, right: B };

function cell(text, w, bg, bold = false, color = "1F2937", size = 18) {
  return new TableCell({
    borders,
    width: { size: w, type: WidthType.DXA },
    shading: { fill: bg, type: ShadingType.CLEAR },
    margins: { top: 100, bottom: 100, left: 140, right: 140 },
    children: [new Paragraph({ children: [new TextRun({ text, font: "Arial", size, bold, color })] })]
  });
}

function hRow(cols, widths) {
  return new TableRow({ children: cols.map((t, i) => cell(t, widths[i], "1E3A5F", true, "FFFFFF", 18)) });
}

function dRow(cols, widths, even) {
  return new TableRow({ children: cols.map((t, i) => cell(t, widths[i], even ? "F0F4FF" : "FFFFFF", i === 0, i === 0 ? "1E3A5F" : "374151")) });
}

function levelBadge(level) {
  // returns a TextRun styled for level badge
  const map = { "MOYEN": ["FF8C00", "⚡ MOYEN"], "DIFFICILE": ["DC2626", "🔥 DIFFICILE"], "EXPERT": ["7C3AED", "💀 EXPERT"] };
  const [color, label] = map[level] || ["6B7280", level];
  return new TextRun({ text: `  [${label}]`, font: "Arial", size: 18, bold: true, color });
}

function h1(text) {
  return new Paragraph({
    children: [new TextRun({ text, font: "Arial", size: 30, bold: true, color: "FFFFFF" })],
    shading: { fill: "1E3A5F", type: ShadingType.CLEAR },
    spacing: { before: 360, after: 0 },
    indent: { left: 180, right: 180 },
    border: { bottom: { style: BorderStyle.SINGLE, size: 8, color: "F59E0B", space: 0 } }
  });
}

function h1sub(text) {
  return new Paragraph({
    children: [new TextRun({ text, font: "Arial", size: 18, color: "BFD7F0", italics: true })],
    shading: { fill: "1E3A5F", type: ShadingType.CLEAR },
    spacing: { before: 0, after: 240 },
    indent: { left: 180 }
  });
}

function h2(text, level) {
  const colors = { "MOYEN": "B45309", "DIFFICILE": "B91C1C", "EXPERT": "6D28D9" };
  const fills  = { "MOYEN": "FFFBEB", "DIFFICILE": "FEF2F2", "EXPERT": "F5F3FF" };
  const bords  = { "MOYEN": "F59E0B", "DIFFICILE": "DC2626", "EXPERT": "7C3AED" };
  const c = colors[level] || "1E3A5F";
  const f = fills[level] || "EFF6FF";
  const bc = bords[level] || "1E3A5F";
  return new Paragraph({
    children: [
      new TextRun({ text, font: "Arial", size: 24, bold: true, color: c }),
      levelBadge(level)
    ],
    shading: { fill: f, type: ShadingType.CLEAR },
    spacing: { before: 280, after: 100 },
    indent: { left: 180, right: 180 },
    border: { left: { style: BorderStyle.SINGLE, size: 14, color: bc, space: 4 } }
  });
}

function h3(text) {
  return new Paragraph({
    children: [new TextRun({ text: "▸ " + text, font: "Arial", size: 21, bold: true, color: "1E3A5F" })],
    spacing: { before: 180, after: 60 },
    indent: { left: 180 }
  });
}

function p(text, color = "374151") {
  return new Paragraph({
    children: [new TextRun({ text, font: "Arial", size: 19, color })],
    spacing: { before: 60, after: 60 },
    indent: { left: 360 }
  });
}

function warn(text) {
  return new Paragraph({
    children: [new TextRun({ text: "⚠️  " + text, font: "Arial", size: 18, bold: true, color: "92400E" })],
    shading: { fill: "FEF3C7", type: ShadingType.CLEAR },
    spacing: { before: 80, after: 80 },
    indent: { left: 360, right: 360 },
    border: { left: { style: BorderStyle.SINGLE, size: 10, color: "F59E0B", space: 4 } }
  });
}

function tip(text) {
  return new Paragraph({
    children: [new TextRun({ text: "✅  " + text, font: "Arial", size: 18, bold: false, color: "065F46" })],
    shading: { fill: "ECFDF5", type: ShadingType.CLEAR },
    spacing: { before: 80, after: 80 },
    indent: { left: 360, right: 360 },
    border: { left: { style: BorderStyle.SINGLE, size: 10, color: "10B981", space: 4 } }
  });
}

function codeBlock(lines) {
  return new Paragraph({
    children: [new TextRun({ text: lines, font: "Courier New", size: 17, color: "E2E8F0" })],
    shading: { fill: "1E293B", type: ShadingType.CLEAR },
    spacing: { before: 80, after: 80 },
    indent: { left: 360, right: 360 }
  });
}

function bullet(text, sub = false) {
  return new Paragraph({
    numbering: { reference: "bullets", level: sub ? 1 : 0 },
    children: [new TextRun({ text, font: "Arial", size: 19, color: "374151" })],
    spacing: { before: 40, after: 40 }
  });
}

function sp(n = 120) {
  return new Paragraph({ spacing: { before: n } });
}

function pb() {
  return new Paragraph({ children: [new PageBreak()] });
}

// ── DOCUMENT ─────────────────────────────────────────────────────────────────
const doc = new Document({
  numbering: {
    config: [
      {
        reference: "bullets",
        levels: [
