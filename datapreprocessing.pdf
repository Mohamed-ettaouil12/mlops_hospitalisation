      new Table({
        width: { size: 9360, type: WidthType.DXA },
        columnWidths: [1800, 2500, 2000, 3060],
        rows: [
          hRow(["Algorithme", "Utilisé par", "Mécanisme", "Impact critique"], [1800, 2500, 2000, 3060]),
          dRow(["BPE (Byte Pair Encoding)", "GPT-2/3/4, LLaMA, Mistral", "Merge paires fréquentes", "Vocab size contrôle le tradeoff speed/quality"], [1800, 2500, 2000, 3060], true),
          dRow(["WordPiece", "BERT, DistilBERT (Google)", "Maximise la log-likelihood", "Meilleur pour les langues morphologiques"], [1800, 2500, 2000, 3060], false),
          dRow(["SentencePiece", "T5, LLaMA, DeepSeek", "BPE/Unigram sur caractères bruts", "Language-agnostic, gère tout Unicode"], [1800, 2500, 2000, 3060], true),
          dRow(["Tiktoken (OpenAI)", "GPT-4, GPT-3.5, Embeddings", "BPE optimisé en Rust", "10-100x plus rapide que HuggingFace"], [1800, 2500, 2000, 3060], false),
        ]
      }),
      sp(80),

      h3("Problèmes critiques de tokenization — ce que les interviews OpenAI testent"),
      bullet("Token fertility : combien de tokens par mot — plus il est élevé, plus le contexte est 'gaspillé'"),
      bullet("Tokenization asymétrique : 'ChatGPT' et 'chatgpt' peuvent avoir des tokens différents"),
      bullet("Tokenization des nombres : '10000' peut être tokenisé comme '100', '00' — cause des bugs arithmétiques"),
      bullet("Whitespace tokenization : les espaces en début de token affectent la sémantique"),
      bullet("Overflow handling : que se passe-t-il quand le texte dépasse la context window ?"),

      codeBlock("import tiktoken"),
      codeBlock(""),
      codeBlock("# Technique d'ingénieurs OpenAI : chunking avec overlap"),
      codeBlock("enc = tiktoken.get_encoding('cl100k_base')  # GPT-4"),
      codeBlock(""),
      codeBlock("def chunk_text(text, max_tokens=512, overlap=50):"),
      codeBlock("    tokens = enc.encode(text)"),
      codeBlock("    chunks = []"),
      codeBlock("    for i in range(0, len(tokens), max_tokens - overlap):"),
      codeBlock("        chunk = tokens[i:i + max_tokens]"),
      codeBlock("        chunks.append(enc.decode(chunk))"),
      codeBlock("    return chunks"),

      warn("Ne jamais chunker sur un nombre fixe de caractères ! Chunker toujours sur les tokens pour éviter de couper les mots en plein milieu et perdre du contexte."),
      sp(80),

      h2("3.2 — Data Deduplication à Grande Échelle", "EXPERT"),
      h3("Pourquoi c'est critique pour les LLMs"),
      p("GPT-3, LLaMA et tous les grands LLMs ont eu des problèmes de duplication dans leurs données d'entraînement. Les données dupliquées causent : mémorisation excessive, surestimation des performances sur benchmarks, biais amplifié."),
      p("L'équipe de DeepMind a montré que 70% du Common Crawl (dataset web géant) est du contenu dupliqué ou quasi-dupliqué."),

      h3("Techniques de déduplication"),
      bullet("Exact deduplication : SHA-256 hash — O(n), simple, ne rate rien"),
      bullet("MinHash + LSH (Locally Sensitive Hashing) — détecte quasi-duplicates, O(n) approximatif"),
      bullet("SimHash — 64-bit fingerprint, très rapide pour grands datasets"),
      bullet("Semantic deduplication : embeddings + cosine similarity — coûteux mais détecte paraphrases"),

      codeBlock("from datasketch import MinHash, MinHashLSH"),
      codeBlock(""),
      codeBlock("# MinHash LSH — utilisé dans l'entraînement de LLaMA"),
      codeBlock("lsh = MinHashLSH(threshold=0.8, num_perm=128)"),
      codeBlock(""),
      codeBlock("def get_minhash(text):"),
      codeBlock("    m = MinHash(num_perm=128)"),
      codeBlock("    for word in text.lower().split():"),
      codeBlock("        m.update(word.encode('utf8'))"),
      codeBlock("    return m"),

      tip("Anthropic utilise une combinaison de MinHash LSH pour la déduplication grossière, puis des embeddings pour la déduplication sémantique fine sur les données d'entraînement de Claude."),
      sp(80),

      h2("3.3 — Data Contamination Detection", "EXPERT"),
      h3("Le problème que personne ne veut admettre"),
      p("La data contamination = quand les données de test/benchmark se trouvent dans les données d'entraînement. Ça donne l'illusion que le modèle est plus intelligent qu'il ne l'est. C'est un problème majeur chez tous les labs."),

      bullet("n-gram overlap : chercher si les questions des benchmarks sont dans le pretraining data"),
      bullet("Membership Inference Attacks : tester si le modèle 'mémorise' des exemples spécifiques"),
      bullet("Perplexity-based detection : le modèle a une perplexité anormalement basse sur les données contaminées"),
      bullet("Canary insertion : insérer des strings uniques dans le training data et vérifier si le modèle les répète"),

      codeBlock("# Détection de contamination par n-gram overlap"),
      codeBlock("from collections import Counter"),
      codeBlock(""),
      codeBlock("def ngram_overlap(text1, text2, n=13):"),
      codeBlock("    def ngrams(text, n):"),
      codeBlock("        tokens = text.lower().split()"),
      codeBlock("        return set(tuple(tokens[i:i+n]) for i in range(len(tokens)-n+1))"),
      codeBlock("    ng1, ng2 = ngrams(text1, n), ngrams(text2, n)"),
      codeBlock("    overlap = len(ng1 & ng2) / len(ng1) if ng1 else 0"),
      codeBlock("    return overlap  # > 0.8 = contamination probable"),

      warn("OpenAI, Anthropic et Google ont tous eu des accusations de data contamination sur leurs benchmarks. C'est maintenant une pratique standard de tester ça avant publication."),
      sp(80),

      h2("3.4 — Quality Filtering des Données Web", "EXPERT"),
      h3("Comment filtrer le Common Crawl comme les grands labs"),
      p("Le web brut est toxique pour les LLMs : spam, contenu adulte, code malveillant, langues rares, texte incompréhensible. Le filtrage est une science à part entière."),

      new Table({
        width: { size: 9360, type: WidthType.DXA },
        columnWidths: [2200, 3500, 3660],
        rows: [
          hRow(["Filtre", "Technique", "Ce que ça élimine"], [2200, 3500, 3660]),
          dRow(["Language Detection", "FastText langid, langdetect", "Contenu non-anglais (si modèle EN)"], [2200, 3500, 3660], true),
          dRow(["Quality Score", "Perplexity KenLM (Wikipedia-trained)", "Texte incohérent, spam, garbled text"], [2200, 3500, 3660], false),
          dRow(["Hate Speech Filter", "Classifier fine-tuné, règles regex", "Contenu toxique, discours haineux"], [2200, 3500, 3660], true),
          dRow(["Document Length", "Seuil min/max tokens", "Pages vides, documents géants mal parsés"], [2200, 3500, 3660], false),
          dRow(["URL/Domain Blocklist", "Liste noire de domaines", "Sites adultes, spam farms, malware"], [2200, 3500, 3660], true),
          dRow(["Repetition Filter", "% de lignes/paragraphes répétés", "Boilerplate, menus, footers répétés"], [2200, 3500, 3660], false),
        ]
      }),

      tip("Le pipeline de filtrage de FineWeb (Hugging Face, 2024) est open-source et est considéré comme l'état de l'art. Il produit des données de meilleure qualité que C4 et Dolma."),
      sp(80),

      h2("3.5 — Feature Stores & Data Versioning", "EXPERT"),
      h3("Ce qu'un Senior Engineer connaît que les autres ignorent"),
      p("En production chez Amazon et Google, les features ne sont jamais recalculées à chaque inférence. Elles sont stockées dans des Feature Stores — des bases de données spécialisées pour le ML."),

      bullet("Feast (open-source) — Feature Store standard de l'industrie, utilisé par Twitter, Gojek"),
      bullet("Tecton — Feature Platform managée (VC-backed, utilisé en finance/fintech)"),
      bullet("Google Vertex AI Feature Store — intégré dans l'écosystème GCP"),
      bullet("Amazon SageMaker Feature Store — AWS, avec online et offline store"),
      bullet("DVC (Data Version Control) — Git pour les données et les modèles"),

      h3("Data Versioning — l'oubli fatal"),
      bullet("Un modèle sans versioning des données est non-reproductible — problème majeur en production"),
      bullet("Chaque dataset doit avoir un hash (SHA-256), une version sémantique, et un lineage"),
      bullet("Delta Lake / Apache Iceberg — time travel sur les datasets, rollback possible"),
      bullet("MLflow avec artifacts — log automatique des datasets utilisés par chaque run"),
      tip("Chez Anthropic, chaque run d'entraînement de Claude est associé à une version exacte du dataset, avec lineage complet. Sans ça, débugger les régressions est impossible."),

      pb(),

      // ══════════════════════════════════════════
