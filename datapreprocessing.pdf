      sp(80),

      h2("2.3 — Détection et Traitement des Outliers", "DIFFICILE"),
      h3("Méthodes de détection"),
      bullet("Z-score : seuil = 3 std — simple mais supposé distribution normale"),
      bullet("IQR (Interquartile Range) : valeur < Q1 - 1.5×IQR ou > Q3 + 1.5×IQR"),
      bullet("Isolation Forest — algorithme ML non supervisé, détecte les anomalies complexes"),
      bullet("DBSCAN — détection par densité, excellent pour données géographiques"),
      bullet("Mahalanobis Distance — détecte outliers multivariés (correlations entre features)"),

      h3("Ce que les ingénieurs experts font"),
      codeBlock("from sklearn.ensemble import IsolationForest"),
      codeBlock(""),
      codeBlock("# Détection automatique des outliers"),
      codeBlock("iso = IsolationForest(contamination=0.05, random_state=42)"),
      codeBlock("outlier_labels = iso.fit_predict(X)  # -1 = outlier, 1 = normal"),
      codeBlock(""),
      codeBlock("# Ne PAS supprimer aveuglément — analyser d'abord"),
      codeBlock("X_clean = X[outlier_labels == 1]"),

