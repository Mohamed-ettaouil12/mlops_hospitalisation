      codeBlock("pipe = Pipeline(["),
      codeBlock("    ('scaler', StandardScaler()),"),
      codeBlock("    ('model', YourModel())"),
      codeBlock("])"),
      codeBlock("pipe.fit(X_train, y_train)  # fit SEULEMENT sur train"),
      codeBlock("pipe.transform(X_test)      # transform seulement, pas fit"),

