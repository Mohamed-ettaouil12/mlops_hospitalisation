      h1("SECTION 4 — LES 10 ERREURS QUI DÉTRUISENT LES MODÈLES"),
      h1sub("Erreurs que même des engineers expérimentés font — identifiées dans des post-mortems réels"),

      sp(100),
      new Table({
        width: { size: 9360, type: WidthType.DXA },
        columnWidths: [360, 2400, 3400, 3200],
        rows: [
          hRow(["#", "Erreur", "Conséquence", "Solution"], [360, 2400, 3400, 3200]),
          dRow(["1", "Data Leakage", "Accuracy irréaliste, modèle inutile en prod", "Pipeline sklearn, fit SEULEMENT sur train"], [360, 2400, 3400, 3200], true),
          dRow(["2", "Imputer avant le split", "Leakage via les statistiques de la moyenne", "Split d'abord, imputer après dans pipeline"], [360, 2400, 3400, 3200], false),
          dRow(["3", "Ignorer le data drift", "Modèle se dégrade avec le temps", "Monitoring Evidently AI, retrain automatique"], [360, 2400, 3400, 3200], true),
          dRow(["4", "Supprimer les outliers sans analyse", "Perdre les événements les plus importants", "Isolation Forest, analyse métier d'abord"], [360, 2400, 3400, 3200], false),
          dRow(["5", "Même scaler sur features de natures différentes", "Features mal normalisées, convergence lente", "Scaler par groupe de features similaires"], [360, 2400, 3400, 3200], true),
          dRow(["6", "Chunking sur caractères (pas tokens)", "Tokens coupés, perte de contexte en LLM", "Toujours utiliser tiktoken ou transformers"], [360, 2400, 3400, 3200], false),
          dRow(["7", "Ignorer la contamination des données", "Benchmarks gonflés, modèle moins bon en réel", "n-gram overlap check avant entraînement"], [360, 2400, 3400, 3200], true),
          dRow(["8", "One-Hot sur haute cardinalité", "Explosion de dimensionnalité (10k+ features)", "Target encoding avec CV ou embeddings"], [360, 2400, 3400, 3200], false),
          dRow(["9", "Pas de reproducibilité (seed/versions)", "Résultats non-reproductibles, bugs impossibles", "DVC + MLflow + random_state=42 partout"], [360, 2400, 3400, 3200], true),
          dRow(["10", "Traitement identique train/inference", "Train-serving skew — le pire bug prod", "Même pipeline code en train et en serving"], [360, 2400, 3400, 3200], false),
        ]
      }),
      sp(100),

      // ══════════════════════════════════════════
