      bullet("Cyclic encoding : sin/cos pour heures, jours, mois (l'heure 23 est proche de 0 !)"),

      h3("Cyclic Encoding — ce que les juniors oublient toujours"),
      codeBlock("import numpy as np"),
      codeBlock("# L'heure 23 et l'heure 0 sont proches — l'encodage naïf rate ça"),
      codeBlock("df['hour_sin'] = np.sin(2 * np.pi * df['hour'] / 24)"),
      codeBlock("df['hour_cos'] = np.cos(2 * np.pi * df['hour'] / 24)"),
      codeBlock("# Pareil pour les mois (12), jours (7), minutes (60)"),
