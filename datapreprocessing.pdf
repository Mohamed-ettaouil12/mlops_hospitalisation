      sp(100),
      h3("Phase 1 : Exploration & Audit"),
      bullet("df.info(), df.describe(), df.isnull().sum() — comprendre le dataset en 5 minutes"),
      bullet("Visualiser les distributions (histogrammes, boxplots) — détecter les anomalies"),
