          dRow(["MAR", "Missing At Random — dépend d'autres features observées", "Multiple Imputation (MICE), modèles prédictifs"], [1800, 3200, 4360], false),
          dRow(["MNAR", "Not At Random — manque parce que la valeur est extrême", "Modéliser le mécanisme de manque, variable indicatrice"], [1800, 3200, 4360], true),
        ]
      }),
      sp(80),

      h3("MICE — Multiple Imputation by Chained Equations"),
      p("Technique utilisée par les data scientists de haut niveau. Impute chaque colonne avec un modèle entraîné sur les autres colonnes, itère plusieurs fois."),
      codeBlock("from sklearn.experimental import enable_iterative_imputer"),
      codeBlock("from sklearn.impute import IterativeImputer"),
      codeBlock(""),
      codeBlock("# MICE avec Random Forest — ce que font les engineers Google"),
      codeBlock("imputer = IterativeImputer("),
      codeBlock("    estimator=RandomForestRegressor(n_estimators=10),"),
      codeBlock("    max_iter=10, random_state=42"),
      codeBlock(")"),
      codeBlock("X_imputed = imputer.fit_transform(X_train)"),
      warn("MICE est 10x plus lent que l'imputation simple. Sur de gros datasets, utilise une stratégie hybride : MICE sur les colonnes importantes, median sur le reste."),
      sp(80),

      h2("2.2 — Feature Engineering Avancé", "DIFFICILE"),
      h3("Interaction Features & Polynomial Features"),
      bullet("Multiplier deux features peut créer des signaux puissants : age × income, distance × frequence"),
